# India page overrides. Copy to .env.india and fill in.
# Keep .env for shared keys (GEMINI_API_KEY, NEWS_API_KEY, etc.).
# Run: python run_india_page.py

# India Facebook page credentials (different from main page)
PAGE_ID=your_india_page_id
PAGE_ACCESS_TOKEN=your_india_page_access_token

# India-only news (newsdata.io country code "in")
NEWS_COUNTRIES=in

# Optional: add neighbouring countries for more volume
# NEWS_COUNTRIES=in,pk,bd

# Caption theme so AI tailors tone for India/South Asia
TOPIC_THEME=India and South Asian news

# Separate posted-articles history so we don't reuse main page's list
POSTED_ARTICLES_FILE=posted_articles_india.json

# Optional: same as above under alternate names
# FACEBOOK_PAGE_ID=your_india_page_id
# FACEBOOK_ACCESS_TOKEN=your_india_page_access_token
