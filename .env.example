# Copy this file to .env and fill in your values. Never commit .env.
#
# Windows + local GPU: use run_continuous_in_this_window.cmd (or call windows_imgen_stable_env.cmd).
# config.py clamps IMGEN_TRY_DIRECT_GPU_FIRST / full-GPU-first unless IMGEN_ALLOW_WINDOWS_DIRECT_GPU_UNSAFE=1.

# Google AI Studio (Gemini) - https://aistudio.google.com/apikey
GEMINI_API_KEY=

# News (optional) - https://newsdata.io/
NEWS_API_KEY=
# Reputed stories: strict window (hours), then relaxed cap if pool empty (still no unfiltered stale fallback).
# NEWS_MAX_AGE_HOURS=8
# NEWS_RELAXED_MAX_AGE_HOURS=48
# Default ON: only US & European financial markets / economy (Newsdata business + filters + finance RSS/Reddit/Google).
# NEWS_MARKETS_US_EUROPE_ONLY=0   # set to restore general breaking news
# Default ON: breaking US/EU market headlines from reputable outlets only (RSS + Newsdata; NO Reddit/Google).
# Set to 0 to allow aggregators + broader finance filter again.
# NEWS_BREAKING_FINANCE_REPUTED_ONLY=1
# Optional: wider pool -- reputed + markets filters stay on; no strict "breaking" shock-word check on titles
# NEWS_REQUIRE_BREAKING_HEADLINE=0
# Default ON: only premier outlets (Reuters, Bloomberg, FT/WSJ/CNBC-tier) count as “reputed” for Newsdata + filters.
# NEWS_REPUTED_PREMIER_ONLY=0   # allow secondary names too (Yahoo Finance, Seeking Alpha, etc.) — weaker “reputed only”
# Optional override: Newsdata category (default business when markets-only). Empty = all categories.
# NEWSDATA_CATEGORY=business
# Optional: comma-separated country codes for Newsdata only (overrides default US+EU list)
# NEWS_COUNTRIES=us,gb,de,fr
# Optional caption theme (otherwise auto-set when markets-only is on)
# TOPIC_THEME=US and European markets and economy

# Facebook Page - from Graph API Explorer or ensure_long_lived_token.py
PAGE_ID=
PAGE_ACCESS_TOKEN=

# Optional: same as above under different names
# FACEBOOK_ACCESS_TOKEN=
# FACEBOOK_PAGE_ID=

# Required for permanent/long-lived Page token (run: python ensure_long_lived_token.py --write-env)
# and for python check_page_token_comments.py (scope list). Meta: App -> Settings -> Basic.
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# Put article URL in the Page’s first comment (default on). Set false to append URL to main caption only.
# NEWS_LINK_IN_FIRST_COMMENT=true
# Hint line on the post pointing to first comment (default on)
# SHOW_FIRST_COMMENT_LINK_HINT=true

GRAPH_API_VERSION=v21.0

# Run full image pipeline (news → caption → image → overlay) but never call the Graph API:
# SKIP_FACEBOOK_POST=1   # or DRY_RUN=1 — also honored by scripts/agent_post_one_cursor.py --no-post

# Posting windows: 7–9am, 12–1pm, 7–10pm **US Eastern** (EST/EDT via America/New_York) unless you override below.
# Default: do NOT set POSTING_SCHEDULE_TIMEZONE → uses America/New_York (US Eastern clock).
# If your PC is in India but the Page is US-focused, still use US Eastern (omit var, or POSTING_SCHEDULE_TIMEZONE=EST or America/New_York).
# Only set IST when you want those same clock numbers on India time:
# POSTING_SCHEDULE_TIMEZONE=IST
# Max POSTS_PER_DAY per **schedule** calendar day. ENABLE_US_ET off = 24/7. Requires tzdata on some Windows.
# ENABLE_US_ET_POSTING_WINDOWS=1
# First run of run_continuous_image_posts.py: skip ET slot wait so the first post attempts immediately (then slots apply).
# Set automatically by run_continuous_image_posts_scheduled.cmd / run_fb_cursor_image_autostart.cmd.
# SKIP_US_ET_WAIT_FIRST_IMAGE_POST=1
# Posting uses evenly spaced slot times inside each window (default). Flood is OFF unless you set both:
# POSTING_SCHEDULE_SLOTS_ONLY=0
# POSTING_SCHEDULE_FLOOD_WINDOWS=1   # or morning

# Facebook post stills — **locked in config.py**: Cursor chat image tool ONLY.
# Read CURSOR_POST_IMAGE_PROMPT.txt, save to cursor_post_image.png (or path in the bundle).
# IMAGE_GENERATION_MODE and ALLOW_FALLBACK_POST_IMAGE in .env are **ignored** — no Z-Image / diffusers / PIL for post art.
# Optional: CURSOR_POST_IMAGE_INBOUND=...  CURSOR_POST_IMAGE_PROMPT_PATH=...  CURSOR_POST_IMAGE_CONSUME=0
# After the prompt file is written, wait this long for the Cursor image tool to save the PNG:
# CURSOR_INBOUND_MAX_WAIT_SECONDS=600
# CURSOR_INBOUND_POLL_INTERVAL_SECONDS=2
# Optional one-shot hook when the prompt is ready (sound, toast .bat): CURSOR_PROMPT_READY_NOTIFY_CMD=cmd /c ...
# Wider safe margins for in-image headline typography in prompts (5-15, default 12): CURSOR_HEADLINE_INSET_PCT=14
# Cursor inbound → output 4:5: cover (default, photo fills frame) | letterbox | headline_safe | center
# CURSOR_INBOUND_CROP_MODE=cover
# cursor_only (default): viral headline/chyron from Cursor image tool only. For PIL headline box (4:5-safe type):
# CURSOR_USE_PIL_HEADLINE_OVERLAY=true
#
# Fully hands-free inbound (optional): run_continuous_image_posts_scheduled.cmd starts scripts/cursor_inbound_auto_bridge.py
# CURSOR_API_KEY=                    # Cursor Dashboard → Integrations → API key
# CURSOR_BACKGROUND_AGENT_REPO=https://github.com/ORG/REPO   # or rely on git remote origin (GitHub HTTPS/git@)
# CURSOR_BACKGROUND_AGENT_REF=main   # unset in .env → default main; explicit empty line → omit ref (API uses GitHub default)
# CURSOR_BACKGROUND_AGENT_AUTO=1     # allow default "auto" bridge mode to use Background Agents API (billing)
# CURSOR_INBOUND_AUTO_MODE=auto      # auto | api | focus | off
# CURSOR_BACKGROUND_AGENT_MAX_WAIT_SECONDS=600
# CURSOR_INBOUND_BRIDGE_POLL_SECONDS=6

# Legacy / other scripts only — not used for Facebook photo posts (Cursor-only policy). CUDA tuning for Z-Image helpers:
# IMGEN_FEB_DEVICE=cuda
# GPU + CPU (model offload): default ON — lower peak VRAM; set false only with plenty of VRAM.
# IMGEN_FEB_USE_CPU_OFFLOAD=true
# Lowest VRAM (slower): IMGEN_SEQUENTIAL_CPU_OFFLOAD=1 in imgen_feb when you still OOM.
# IMGEN_SEQUENTIAL_CPU_OFFLOAD=0
# Full-GPU first (needs ~16+ GB VRAM on Windows — below that imgen_feb skips it to avoid native crash). See PERFORMANCE.md
# IMGEN_TRY_DIRECT_GPU_FIRST=1
# Required on Windows for STRATEGY 1 together with line above (default 0 in config):
# IMGEN_ALLOW_WINDOWS_DIRECT_GPU=1
# Override VRAM floor (GB) for Windows full-GPU attempt (default 16):
# IMGEN_WINDOWS_DIRECT_GPU_MIN_VRAM_GB=16
# Last resort: allow full-GPU on low VRAM (may crash): IMGEN_ALLOW_WINDOWS_DIRECT_GPU_UNSAFE=1
# If config forces IMGEN_FORCE_CPU_OFFLOAD=1 and you want auto threshold instead: IMGEN_WIN_SKIP_FORCE_CPU_OFFLOAD=1
# Fewer threads while loading multi-GB weights on Windows (default 4): IMGEN_WIN_MODEL_LOAD_OMP_THREADS=4
# Local Z-Image via diffusers (module file: runpod_image.py — not a remote RunPod unless RUNPOD_IMAGE_API_URL is set).
# Prefer local diffusers before imgen_feb: IMGEN_PREFER_LOCAL_DIFFUSERS_FIRST=1 (legacy name: IMGEN_PREFER_RUNPOD_IMAGE_LOCAL=1)
# Windows CUDA load tuning (aliases in parentheses — older IMGEN_RUNPOD_* still work):
# IMGEN_LOCAL_ZIMAGE_BF16=1  (was IMGEN_RUNPOD_WINDOWS_BFLOAT16=1) — bfloat16 load; default fp16
# IMGEN_LOCAL_ZIMAGE_DISABLE_OFFLOAD_STATE_DICT=1 — skip disk offload during assembly
# IMGEN_LOCAL_ZIMAGE_LOW_CPU_MEM=0 — disable meta/low-RAM load (if it crashes)
# Auto offload if VRAM below this GB (default 14). Lower = more likely full-GPU on borderline cards.
# IMGEN_OFFLOAD_VRAM_THRESHOLD_GB=14
# Always model offload (safest, slowest): IMGEN_FORCE_CPU_OFFLOAD=1
# Faster diffusion (optional): IMGEN_FEB_INFERENCE_STEPS=6
# Reload model every image (slow 24/7): IMGEN_FEB_CLEAR_PIPELINE_AFTER_GENERATE=true
# Require GPU (no silent CPU fallback if CUDA missing):
# IMGEN_ALLOW_CPU_FALLBACK=false
# Legacy template key (optional). imgen feb probes CUDA with a real kernel test for sm_91+.
# IMGEN_SKIP_GPU_CAPABILITY_CHECK=1
# Force CPU only if you must (slow):
# IMGEN_FEB_DEVICE=cpu

# PIL placeholders for posts: permanently disabled in code (cannot enable via .env).

# Strict startup (CUDA checks + Z-Image warm load). Enabled by run_local.cmd / run_continuous_*_helper.cmd. Optional manual enable:
# STRICT_IMAGE_GEN=1
# IMAGE_GEN_WARM_LOAD=1
# Quick dev without preflight:
# STRICT_IMAGE_GEN=0
# IMAGE_GEN_WARM_LOAD=0

# Image look: default is classic (photoreal news). Optional: institutional = dark terminal / abstract charts (not default).
# IMAGE_VISUAL_MODE=classic
# IMAGE_VISUAL_MODE=institutional
# Optional accent (hex) for glow lines + overlay when institutional:
# INSTITUTIONAL_ACCENT_HEX=#00B8D4

# Hugging Face: PyTorch-only image gen (avoids loading TensorFlow → protobuf version clash). Defaults are set in code; override only if needed:
# USE_TORCH=1
# USE_TF=0

# Optional: use Ollama for caption/image prompt (default true if Ollama running)
# USE_OLLAMA=true
# OLLAMA_BASE_URL=http://localhost:11434
# When Ollama is shared by multiple projects: set OLLAMA_NUM_PARALLEL=4 (or higher) on the Ollama SERVER machine and restart Ollama (see README §8).
# Client-side fallbacks when server is busy:
# OLLAMA_TIMEOUT=600
# OLLAMA_RETRIES=3
# OLLAMA_RETRY_DELAY=30

# Optional: split setup — RunPod runs only image gen (runpod_image_server.py); VPS runs the rest.
# Set on VPS to your RunPod server URL, e.g. http://<RUNPOD_PUBLIC_IP>:5000
# RUNPOD_IMAGE_API_URL=

# Optional: for one-command RunPod setup from your PC.
# Option A – proxy: set RUNPOD_SSH_USER (from Connect tab; refresh if Pod was migrated).
# Option A2 – Direct TCP (same container as Web terminal): set RUNPOD_SSH_HOST and RUNPOD_SSH_PORT from Connect tab.
# Option B – create pod automatically: set RUNPOD_API_KEY (get from console.runpod.io → Settings → API Keys).
#   Add your SSH public key in RunPod account settings. Install runpodctl for full automation (no console step).
# RUNPOD_SSH_USER=
# RUNPOD_SSH_HOST=194.26.196.139
# RUNPOD_SSH_PORT=44718
# RUNPOD_SSH_KEY=C:\Users\user\.ssh\id_ed25519
# RUNPOD_SINGLE_CONNECTION=1  # Deploy in one SSH session and drop into shell in same container (avoids proxy load-balancing).
# RUNPOD_API_KEY=
# RUNPOD_GPU_TYPE=NVIDIA RTX 2000 Ada Generation
# RUNPOD_IMAGE=runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04
# RUNPOD_POD_NAME=auto-posting-facebook
