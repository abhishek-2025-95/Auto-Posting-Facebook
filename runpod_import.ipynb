   "source": [
    "# Auto Post to Facebook — RunPod Image API\n",
    "\n",
    "Run one full cycle using a **remote RunPod image server** (no GPU needed in this notebook):\n",
    "\n",
    "**News** → **Caption + image prompt (Gemini)** → **Image (RunPod API)** → **Overlay** → **Post to Facebook**\n",
    "\n",
    "---\n",
    "\n",
    "## Setup\n",
    "\n",
    "1. **RunPod**  
",
    "   - Have your image server running on RunPod (`python runpod_image_server.py` on the pod, or use `setup_runpod.py` from your PC).  \n",
    "   - Note the URL: `http://<pod-ip>:<port>` (from RunPod Connect → Direct TCP for port 5000).  \n",
    "   - If you use an SSH tunnel from your PC: `http://127.0.0.1:5000`.\n",
    "\n",
    "2. **Secrets / env** (Kaggle: Add-ons → Secrets; Colab: set in cell; local: `.env`)  \n",
    "   - `GEMINI_API_KEY` — [Google AI Studio](https://aistudio.google.com/apikey)  \n",
    "   - `RUNPOD_IMAGE_API_URL` — e.g. `http://213.173.99.11:18168` or `http://127.0.0.1:5000`  \n",
    "   - `PAGE_ID`, `PAGE_ACCESS_TOKEN` — Facebook Page  \n",
    "   - `NEWS_API_KEY` — optional ([newsdata.io](https://newsdata.io/)); if missing, uses BBC RSS.\n",
    "\n",
    "3. **Run**  \n",
    "   - **Run All**. Image is generated on RunPod; this notebook only sends the prompt and receives the image."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 1: Load secrets and set RunPod URL\n",
    "import os\n",
    "import sys\n",
    "import subprocess\n",
    "\n",
    "try:\n",
    "    from kaggle_secrets import UserSecretsClient\n",
    "    s = UserSecretsClient()\n",
    "    for key in [\"GEMINI_API_KEY\", \"GOOGLE_API_KEY\", \"NEWS_API_KEY\", \"PAGE_ACCESS_TOKEN\", \"PAGE_ID\", \"RUNPOD_IMAGE_API_URL\"]:\n",
    "        try:\n",
    "            os.environ[key] = s.get_secret(key)\n",
    "        except Exception:\n",
    "            pass\n",
    "except Exception:\n",
    "    pass\n",
    "\n",
    "if os.environ.get(\"GEMINI_API_KEY\") and not os.environ.get(\"GOOGLE_API_KEY\"):\n",
    "    os.environ[\"GOOGLE_API_KEY\"] = os.environ[\"GEMINI_API_KEY\"]\n",
    "\n",
    "RUNPOD_IMAGE_API_URL = os.environ.get(\"RUNPOD_IMAGE_API_URL\", \"\").strip().rstrip(\"/\")\n",
    "if not RUNPOD_IMAGE_API_URL:\n",
    "    RUNPOD_IMAGE_API_URL = \"http://127.0.0.1:5000\"  # default for SSH tunnel\n",
    "    print(\"Using RUNPOD_IMAGE_API_URL:", RUNPOD_IMAGE_API_URL, \"(set in Secrets or .env to override)\")\n",
    "else:\n",
    "    print(\"RUNPOD_IMAGE_API_URL:\", RUNPOD_IMAGE_API_URL)\n",
    "\n",
    "subprocess.run([sys.executable, \"-m\", \"pip\", \"install\", \"-q\", \"google-genai\", \"feedparser\", \"requests\"], capture_output=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 2: Fetch one news article (Newsdata.io or BBC RSS fallback)\n",
    "import requests\n",
    "\n",
    "article = None\n",
    "api_key = os.environ.get(\"NEWS_API_KEY\", \"\").strip()\n",
    "\n",
    "if api_key:\n",
    "    try:\n",
    "        r = requests.get(\"https://newsdata.io/api/1/latest\", params={\"apikey\": api_key, \"language\": \"en\", \"country\": \"us\"}, timeout=15)\n",
    "        r.raise_for_status()\n",
    "        res = r.json().get(\"results\", [])\n",
    "        if res:\n",
    "            a = res[0]\n",
    "            article = {\n",
    "                \"title\": (a.get(\"title\") or a.get(\"title_full\", \"\"))[:200],\n",
    "                \"description\": (a.get(\"description\") or a.get(\"content\") or \"\")[:500],\n",
    "                \"url\": a.get(\"link\") or a.get(\"url\", \"\"),\n",
    "                \"source\": a.get(\"source_id\", \"News\"),\n",
    "            }\n",
    "            print(\"Article (newsdata.io):\", article[\"title\"][:60], \"...\")\n",
    "    except Exception as e:\n",
    "        print(\"Newsdata.io error:\", e)\n",
    "\n",
    "if not article:\n",
    "    try:\n",
    "        import feedparser\n",
    "        fp = feedparser.parse(\"https://feeds.bbci.co.uk/news/rss.xml\", request_headers={\"User-Agent\": \"Notebook/1.0\"})\n",
    "        entries = fp.get(\"entries\", [])\n",
    "        if entries:\n",
    "            e = entries[0]\n",
    "            article = {\n",
    "                \"title\": (e.get(\"title\") or \"\")[:200],\n",
    "                \"description\": (e.get(\"summary\", \"\") or e.get(\"title\", \"\"))[:500],\n",
    "                \"url\": e.get(\"link\", \"\"),\n",
    "                \"source\": \"BBC News\",\n",
    "            }\n",
    "            print(\"Article (BBC RSS):\", article[\"title\"][:60], \"...\")\n",
    "    except Exception as e:\n",
    "        print(\"BBC RSS error:\", e)\n",
    "\n",
    "if not article:\n",
    "    article = {\"title\": \"Markets Open Higher Amid Earnings Wave\", \"description\": \"Stocks rise.\", \"url\": \"\", \"source\": \"Sample\"}\n",
    "    print(\"Using sample article.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 3: Gemini caption + image prompt\n",
    "api_key = os.environ.get(\"GEMINI_API_KEY\") or os.environ.get(\"GOOGLE_API_KEY\", \"\").strip()\n",
    "if not api_key:\n",
    "    raise ValueError(\"Set GEMINI_API_KEY in Secrets or .env. Get a key at https://aistudio.google.com/apikey\")\n",
    "\n",
    "from google import genai\n",
    "client = genai.Client(api_key=api_key)\n",
    "\n",
    "GEMINI_MODELS = [\"gemini-2.0-flash\", \"gemini-1.5-flash-latest\", \"gemini-1.5-pro-latest\", \"gemini-pro\"]\n",
    "gemini_model = None\n",
    "for m in GEMINI_MODELS:\n",
    "    try:\n",
    "        r = client.models.generate_content(model=m, contents=\"Say OK\")\n",
    "        if getattr(r, \"text\", None) or (getattr(r, \"candidates\", None) and len(r.candidates) > 0):\n",
    "            gemini_model = m\n",
    "            print(\"Using model:\", gemini_model)\n",
    "            break\n",
    "    except Exception:\n",
    "        continue\n",
    "if not gemini_model:\n",
    "    gemini_model = \"gemini-2.0-flash\"\n",
    "\n",
    "def _gemini_text(r):\n",
    "    if hasattr(r, \"text\") and r.text:\n",
    "        return r.text\n",
    "    if hasattr(r, \"candidates\") and r.candidates:\n",
    "        c = r.candidates[0]\n",
    "        if hasattr(c, \"content\") and c.content and hasattr(c.content, \"parts\"):\n",
    "            for part in c.content.parts:\n",
    "                if hasattr(part, \"text\") and part.text:\n",
    "                    return part.text\n",
    "    return \"\"\n",
    "\n",
    "def gemini_caption(art):\n",
    "    p = f\"\"\"You are a senior US news editor. Based on this article write a Facebook caption.\n",
    "Title: {art['title']}\n",
    "Description: {art['description']}\n",
    "Start with BREAKING: or JUST IN:. 180-250 words. End with 20-30 hashtags. No emojis. Return only the caption.\"\"\"\n",
    "    r = client.models.generate_content(model=gemini_model, contents=p)\n",
    "    return (_gemini_text(r) or \"\").strip()\n",
    "\n",
    "def gemini_image_prompt(art):\n",
    "    p = f\"\"\"One sentence image prompt for photorealistic, dramatic news-style image about: {art['title']}. No text in image. Vivid.\"\"\"\n",
    "    r = client.models.generate_content(model=gemini_model, contents=p)\n",
    "    return ((_gemini_text(r) or \"\").strip().strip('\"'))[:500]\n",
    "\n",
    "caption = gemini_caption(article)\n",
    "image_prompt = gemini_image_prompt(article)\n",
    "print(\"Caption len:\", len(caption), \"| Prompt:\", image_prompt[:70], \"...\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 4: Generate image via RunPod API (Z-Image-Turbo on RunPod)\n",
    "import requests\n",
    "\n",
    "prompt = (image_prompt or \"Professional news scene\") + \" Vivid, saturated colors; lively and eye-catching palette.\"\n",
    "width, height = 768, 960  # 4:5 portrait\n",
    "\n",
    "out_path = \"/kaggle/working/post_image.jpg\" if os.path.exists(\"/kaggle\") else \"post_image.jpg\"\n",
    "\n",
    "print(\"Calling RunPod image API...\")\n",
    "r = requests.post(\n",
    "    f\"{RUNPOD_IMAGE_API_URL}/generate\",\n",
    "    json={\"prompt\": prompt, \"width\": width, \"height\": height},\n",
    "    timeout=600,\n",
    ")\n",
    "r.raise_for_status()\n",
    "with open(out_path, \"wb\") as f:\n",
    "    f.write(r.content)\n",
    "print(\"Saved:\", out_path)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 5: Headline overlay\n",
    "from PIL import Image, ImageDraw, ImageFont\n",
    "\n",
    "img = Image.open(out_path).convert(\"RGB\")\n",
    "draw = ImageDraw.Draw(img)\n",
    "w, h = img.size\n",
    "bar_h = int(h * 0.25)\n",
    "draw.rectangle([0, h - bar_h, w, h], fill=(20, 30, 60))\n",
    "\n",
    "headline = \" \".join((article.get(\"title\") or \"Breaking News\")[:80].split()[:10])\n",
    "try:\n",
    "    font = ImageFont.truetype(\"/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf\", min(48, w // 18))\n",
    "except Exception:\n",
    "    try:\n",
    "        font = ImageFont.truetype(\"arial.ttf\", min(48, w // 18))\n",
    "    except Exception:\n",
    "        font = ImageFont.load_default()\n",
    "\n",
    "bbox = draw.textbbox((0, 0), headline, font=font)\n",
    "tw, th = bbox[2] - bbox[0], bbox[3] - bbox[1]\n",
    "draw.text(((w - tw) // 2, h - bar_h + (bar_h - th) // 2), headline, fill=(255, 255, 255), font=font)\n",
    "img.save(out_path, quality=95)\n",
    "print(\"Overlay done.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 6: Post to Facebook\n",
    "pid = os.environ.get(\"PAGE_ID\", \"\").strip()\n",
    "token = os.environ.get(\"PAGE_ACCESS_TOKEN\", \"\").strip()\n",
    "\n",
    "if not pid or not token:\n",
    "    print(\"Add PAGE_ID and PAGE_ACCESS_TOKEN in Secrets to post to Facebook.\")\n",
    "    print(\"Image saved to\", out_path)\n",
    "else:\n",
    "    url = f\"https://graph.facebook.com/v21.0/{pid}/photos\"\n",
    "    with open(out_path, \"rb\") as f:\n",
    "        r = requests.post(url, files={\"source\": f}, data={\"access_token\": token, \"caption\": caption[:63000], \"published\": \"true\"}, timeout=60)\n",
    "    if r.ok:\n",
    "        print(\"SUCCESS: Posted to Facebook.\")\n",
    "    else:\n",
    "        print(\"Post failed:\", r.status_code, r.text[:300])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 7: Display generated image\n",
    "from PIL import Image\n",
    "display(Image.open(out_path))"
   ]
  }
